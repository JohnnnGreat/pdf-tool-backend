# Environment — never commit secrets
.env
.env.prod
.env.local

# Python
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/
.coverage
htmlcov/
.maturin/
target/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# SQLite dev database
*.db

# Runtime data — not source code
uploads/*
outputs/*
!uploads/.gitkeep
!outputs/.gitkeep

# Nginx logs (mounted as volume)
nginx/logs/

# Rust / Cargo cache (downloaded by Docker build, not source code)
.cargo-home/
cargo-home/

# Processed file results (runtime output, not source code)
results/

# Test/sample files
*.pdf
*.docx
*.doc
*.xlsx
*.pptx
