# =============================================================================
# DocForge Backend — Environment Variables
# Copy this file to .env and fill in all values.
# Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=DocForge API
DEBUG=true
PORT=8000

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ---------------------------------------------------------------------------
# Database
# For local dev without Docker, SQLite is fine:
#   DATABASE_URL=sqlite:///./docforge.db
# When using docker-compose.yml, this is overridden automatically.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://docforge:docforge@localhost:5432/docforge

# ---------------------------------------------------------------------------
# Redis (optional — enables distributed rate limiting and caching)
# When using docker-compose.yml, this is overridden automatically.
# Leave blank to use the in-memory fallback.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Authentication / JWT
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---------------------------------------------------------------------------
# File handling
# ---------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=20
TEMP_FILE_RETENTION_MINUTES=60
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ---------------------------------------------------------------------------
# OCR — Tesseract
# Leave blank to use system PATH. Set explicitly if using a non-standard path.
# Docker: /usr/bin/tesseract (set automatically by docker-compose)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS (brew): /usr/local/bin/tesseract
# ---------------------------------------------------------------------------
TESSERACT_PATH=
TESSERACT_LANG=eng

# ---------------------------------------------------------------------------
# Document conversion — LibreOffice
# Leave blank to use system PATH.
# Docker: /usr/bin/libreoffice (set automatically by docker-compose)
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
# macOS (brew): /Applications/LibreOffice.app/Contents/MacOS/soffice
# ---------------------------------------------------------------------------
LIBREOFFICE_PATH=

# ---------------------------------------------------------------------------
# Payment providers (leave blank if not using)
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
LEMONSQUEEZY_WEBHOOK_SECRET=
COINBASE_WEBHOOK_SECRET=

PAYMENT_CALLBACK_URL=http://localhost:3000/dashboard/upgrade/success

# ---------------------------------------------------------------------------
# Email (SMTP) — required for email verification and password reset
# Leave SMTP_HOST blank to disable email sending (tokens will appear in logs).
# Examples: smtp.gmail.com (port 587 TLS), smtp.sendgrid.net, etc.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@docforge.com
SMTP_FROM_NAME=DocForge
SMTP_TLS=true

# Frontend base URL — used to build links in verification/reset emails
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# AWS S3 (optional — for cloud file storage instead of local disk)
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
