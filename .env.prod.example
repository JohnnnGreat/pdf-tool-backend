# =============================================================================
# DocForge Backend — PRODUCTION Environment Variables
# Copy this file to .env.prod and fill in every value.
# Never commit .env.prod to git.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=DocForge API
DEBUG=false
PORT=8000

SECRET_KEY=GENERATE_A_STRONG_RANDOM_SECRET_HERE

# ---------------------------------------------------------------------------
# Database
# (DATABASE_URL is overridden by docker-compose.prod.yml to use the compose
#  postgres service. Set POSTGRES_PASSWORD here — it is referenced in compose.)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=GENERATE_A_STRONG_POSTGRES_PASSWORD_HERE

# ---------------------------------------------------------------------------
# Redis
# (REDIS_URL is overridden by docker-compose.prod.yml)
# Set REDIS_PASSWORD here — it is passed to the Redis container.
# ---------------------------------------------------------------------------
REDIS_PASSWORD=GENERATE_A_STRONG_REDIS_PASSWORD_HERE

# ---------------------------------------------------------------------------
# Authentication / JWT
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS — set to your actual frontend domain(s)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ---------------------------------------------------------------------------
# File handling
# ---------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_REQUEST=20
TEMP_FILE_RETENTION_MINUTES=60
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs

# ---------------------------------------------------------------------------
# Rate limiting (tighter limits in production)
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ---------------------------------------------------------------------------
# OCR / LibreOffice — paths are fixed inside the Docker container
# Do not change these unless you are running outside Docker.
# ---------------------------------------------------------------------------
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng
LIBREOFFICE_PATH=/usr/bin/libreoffice

# ---------------------------------------------------------------------------
# Gunicorn worker count
# Rule of thumb: (2 × CPU cores) + 1
# e.g. 2-core VPS → 5 workers
# ---------------------------------------------------------------------------
GUNICORN_WORKERS=5

# ---------------------------------------------------------------------------
# Payment providers
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=GENERATE_A_STRONG_WEBHOOK_SECRET_HERE

PAYSTACK_SECRET_KEY=sk_live_YOUR_PAYSTACK_KEY
FLUTTERWAVE_SECRET_KEY=FLWSECK_YOUR_FLUTTERWAVE_KEY
FLUTTERWAVE_SECRET_HASH=YOUR_FLUTTERWAVE_HASH
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR_LEMONSQUEEZY_SECRET
COINBASE_WEBHOOK_SECRET=YOUR_COINBASE_SECRET

PAYMENT_CALLBACK_URL=https://yourdomain.com/dashboard/upgrade/success

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
GROQ_API_KEY=YOUR_GROQ_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ---------------------------------------------------------------------------
# AWS S3 (recommended for production — store files in S3, not local disk)
# ---------------------------------------------------------------------------
S3_BUCKET=docforge-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
S3_SECRET_KEY=YOUR_AWS_SECRET_KEY
